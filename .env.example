# Root environment template for local development.
# Production deployments should set these in the host platform instead of committing a real .env.

# API server
DATABASE_URL=postgres://postgres:socialhub@localhost:5433/social_hub
PORT=3001
SESSION_SECRET=replace-this-with-a-real-secret
CORS_ORIGINS=http://localhost:5173
TRUST_PROXY=false
SESSION_COOKIE_NAME=socialhub.sid
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_DOMAIN=
MEDIA_STORAGE_PROVIDER=local
LOCAL_UPLOAD_ROOT=
LOCAL_UPLOAD_PUBLIC_BASE_URL=
UPLOAD_ROOT=
UPLOAD_PUBLIC_BASE_URL=

# Frontend dev server
BASE_PATH=/
VITE_API_BASE_URL=http://localhost:3001
